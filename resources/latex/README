\newcommand*{\diff}[3][]{\frac{\!\textrm{d}^{#1} #2}{\textrm{d}#3^{#1}}}

% Declaring math operators. Could also use \newcommand{\name}{\operatorname{name}}
\DeclareMathOperator{\cosec}{cosec}
\DeclareMathOperator{\powop}{pow} %\newcommand{\pow}{\operatorname{pow}}

$\definecolor{frog}{rgb}{1,0,0}$
